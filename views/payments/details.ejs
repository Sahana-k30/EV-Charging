<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2 class="mb-0">Payment Details</h2>
                    <% if (payment.status === 'Failed' || payment.status === 'Pending') { %>
                        <button onclick="retryPayment('<%= payment._id %>')" class="btn btn-warning">
                            <i class="fas fa-redo"></i> Retry Payment
                        </button>
                    <% } %>
                </div>
                <div class="card-body">
                    <!-- Payment Information -->
                    <div class="mb-4">
                        <h5>Payment Information</h5>
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Payment ID:</strong> <%= payment._id %></p>
                                <p><strong>Date:</strong> <%= new Date(payment.createdAt).toLocaleString() %></p>
                                <p><strong>Status:</strong> 
                                    <% if (payment.status === 'Completed') { %>
                                        <span class="badge bg-success">Completed</span>
                                    <% } else if (payment.status === 'Processing') { %>
                                        <span class="badge bg-warning">Processing</span>
                                    <% } else if (payment.status === 'Failed') { %>
                                        <span class="badge bg-danger">Failed</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary">Pending</span>
                                    <% } %>
                                </p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Amount:</strong> $<%= payment.amount.toFixed(2) %></p>
                                <p><strong>Payment Method:</strong> <%= payment.paymentMethod %></p>
                                <% if (payment.status === 'Failed') { %>
                                    <p class="text-danger"><strong>Error:</strong> <%= payment.error || 'Unknown error' %></p>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- Booking Details -->
                    <% if (payment.booking) { %>
                        <div class="mb-4">
                            <h5>Booking Details</h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <p><strong>Station:</strong> <%= payment.booking.station.name %></p>
                                    <p><strong>Start Time:</strong> <%= new Date(payment.booking.startTime).toLocaleString() %></p>
                                    <p><strong>End Time:</strong> <%= new Date(payment.booking.endTime).toLocaleString() %></p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong>Energy Consumed:</strong> <%= payment.booking.energyConsumed %> kWh</p>
                                    <p><strong>Duration:</strong> <%= Math.round((payment.booking.endTime - payment.booking.startTime) / (1000 * 60)) %> minutes</p>
                                    <p><strong>Vehicle:</strong> <%= payment.booking.vehicle.make %> <%= payment.booking.vehicle.model %></p>
                                </div>
                            </div>
                        </div>

                        <!-- Cost Breakdown -->
                        <div class="mb-4">
                            <h5>Cost Breakdown</h5>
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <tr>
                                        <td>Energy Cost</td>
                                        <td class="text-end">$<%= payment.breakdown.energyCost.toFixed(2) %></td>
                                    </tr>
                                    <tr>
                                        <td>Parking Cost</td>
                                        <td class="text-end">$<%= payment.breakdown.parkingCost.toFixed(2) %></td>
                                    </tr>
                                    <% if (payment.breakdown.discount > 0) { %>
                                        <tr>
                                            <td>Discount</td>
                                            <td class="text-end text-success">-$<%= payment.breakdown.discount.toFixed(2) %></td>
                                        </tr>
                                    <% } %>
                                    <tr>
                                        <td>Tax (10%)</td>
                                        <td class="text-end">$<%= payment.breakdown.tax.toFixed(2) %></td>
                                    </tr>
                                    <tr class="fw-bold">
                                        <td>Total</td>
                                        <td class="text-end">$<%= payment.amount.toFixed(2) %></td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    <% } %>

                    <div class="mt-4">
                        <a href="/payments" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Back to Payments
                        </a>
                        <% if (payment.status === 'Completed') { %>
                            <button onclick="downloadReceipt('<%= payment._id %>')" class="btn btn-primary">
                                <i class="fas fa-download"></i> Download Receipt
                            </button>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- contentFor('scripts') %>
<script>
function retryPayment(paymentId) {
    if (confirm('Are you sure you want to retry this payment?')) {
        fetch(`/payments/${paymentId}/retry`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }
        })
        .then(response => {
            if (response.ok) {
                window.location.reload();
            } else {
                throw new Error('Failed to retry payment');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error retrying payment');
        });
    }
}

function downloadReceipt(paymentId) {
    window.location.href = `/payments/${paymentId}/receipt`;
}
</script>

<%- contentFor('styles') %>
<style>
.badge {
    font-size: 0.9em;
}

.table td {
    padding: 0.5rem;
}

.btn {
    margin-right: 0.5rem;
}

.btn:last-child {
    margin-right: 0;
}
</style> 