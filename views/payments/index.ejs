<div class="container mt-4">
    <% if (!locals.user) { %>
        <div class="alert alert-info text-center">Demo: You are viewing sample payment data.</div>
    <% } %>
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-end gap-2">
            <a href="/payments/demo-analysis" class="btn btn-outline-success btn-sm">View Payment Analysis (Demo)</a>
            <button class="btn btn-outline-primary btn-sm" onclick="alert('This would open a payment form in a real app.')">Make a Payment (Demo)</button>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Payment History</h2>
            </div>

            <% if (payments && payments.length > 0) { %>
                <div class="row">
                    <% payments.forEach(payment => { %>
                        <div class="col-md-6 mb-4">
                            <div class="card payment-card">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <h5 class="card-title mb-0">
                                            Payment #<%= payment.paymentId %>
                                        </h5>
                                        <span class="badge bg-<%= payment.status === 'Completed' ? 'success' : 'warning' %> status-badge">
                                            <%= payment.status %>
                                        </span>
                                    </div>

                                    <p class="card-text">
                                        <strong>Booking:</strong> 
                                        <%= payment.booking.station.name %>
                                    </p>

                                    <p class="card-text">
                                        <strong>Date:</strong> 
                                        <%= new Date(payment.date).toLocaleDateString() %>
                                    </p>

                                    <p class="card-text">
                                        <strong>Amount:</strong> 
                                        $<%= payment.amount.toFixed(2) %>
                                    </p>

                                    <p class="card-text">
                                        <strong>Payment Method:</strong> 
                                        <%= payment.paymentMethod %>
                                    </p>

                                    <div class="mt-3">
                                        <a href="/payments/demo/<%= payment._id %>" class="btn btn-info btn-sm">
                                            <i class="fas fa-info-circle"></i> Details (Demo)
                                        </a>
                                        <% if (payment.status === 'Completed') { %>
                                            <button onclick="alert('This would download a receipt in a real app.')" 
                                                    class="btn btn-primary btn-sm ms-2">
                                                <i class="fas fa-download"></i> Receipt (Demo)
                                            </button>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> No payment history found.
                </div>
            <% } %>
        </div>
    </div>
</div>

<style>
.payment-card {
    transition: transform 0.2s;
}
.payment-card:hover {
    transform: translateY(-5px);
}
.status-badge {
    font-size: 0.8rem;
}
</style>

<script>
function downloadReceipt(paymentId) {
    window.location.href = '/payments/' + paymentId + '/receipt';
}
</script> 