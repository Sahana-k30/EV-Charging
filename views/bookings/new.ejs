<%- contentFor('body') %>
<div class="container mt-4">
    <div class="row">
        <div class="col-md-12 mb-4">
            <h2><i class="bi bi-calendar-plus"></i> Book a Charging Session</h2>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <form id="bookingForm" method="POST" action="/bookings">
                        <input type="hidden" name="stationId" value="<%= selectedStationId || '' %>">

                        <% if (station && station.chargingPoints && station.chargingPoints.length > 0) { %>
                          <div class="mb-4">
                            <h5><i class="bi bi-plug"></i> Select Charging Point</h5>
                            <select class="form-select" id="chargingPoint" name="chargingPoint" required>
                              <% station.chargingPoints.filter(point => point.status === 'Available').forEach((point, idx) => { %>
                                <option value='<%- JSON.stringify({ pointId: idx.toString(), type: point.type, power: point.power }) %>'>
                                  <%= point.type %> - <%= point.power %> kW (Point <%= idx + 1 %>)
                                </option>
                              <% }); %>
                            </select>
                          </div>
                        <% } else { %>
                          <div class="alert alert-warning">No available charging points for this station.</div>
                        <% } %>

                        <!-- Vehicle Selection -->
                        <div class="mb-4">
                            <h5><i class="bi bi-car-front"></i> Select Vehicle</h5>
                            <select class="form-select" id="vehicleId" name="vehicleId" required>
                                <option value="">Choose a vehicle...</option>
                                <% if (locals.vehicles && vehicles.length > 0) { %>
                                    <% vehicles.forEach(vehicle => { %>
                                        <option value="<%= vehicle._id.toString() %>">
                                            <%= vehicle.make %> <%= vehicle.model %> (<%= vehicle.licensePlate %>)
                                        </option>
                                    <% }); %>
                                <% } %>
                            </select>
                        </div>

                        <!-- Time Selection -->
                        <div class="mb-4">
                            <h5><i class="bi bi-clock"></i> Select Time</h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Start Time</label>
                                        <input type="datetime-local" class="form-control" 
                                               id="startTime" name="startTime" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Duration (hours)</label>
                                        <input type="number" class="form-control" 
                                               id="duration" name="duration" 
                                               min="0.5" max="24" step="0.5" required>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Charging Details -->
                        <div class="mb-4">
                            <h5><i class="bi bi-battery-charging"></i> Charging Details</h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Current Battery Level (%)</label>
                                        <input type="number" class="form-control" 
                                               id="currentBattery" name="currentBattery" 
                                               min="0" max="100" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Target Battery Level (%)</label>
                                        <input type="number" class="form-control" 
                                               id="targetBattery" name="targetBattery" 
                                               min="0" max="100" required>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-lightning-charge"></i> Book Session
                            </button>
                            <a href="/dashboard" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back to Dashboard
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Booking Summary -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-receipt"></i> Booking Summary</h5>
                </div>
                <div class="card-body">
                    <div id="summaryContent" style="display: none;">
                        <div class="mb-3">
                            <h6>Selected Vehicle</h6>
                            <p id="selectedVehicleInfo" class="mb-0"></p>
                        </div>
                        <div class="mb-3">
                            <h6>Charging Session</h6>
                            <p id="sessionInfo" class="mb-0"></p>
                        </div>
                        <div class="mb-3">
                            <h6>Estimated Cost</h6>
                            <table class="table table-sm">
                                <tr>
                                    <td>Charging Cost</td>
                                    <td class="text-end" id="chargingCost">$0.00</td>
                                </tr>
                                <tr>
                                    <td>Service Fee</td>
                                    <td class="text-end" id="serviceFee">$0.00</td>
                                </tr>
                                <tr class="fw-bold">
                                    <td>Total</td>
                                    <td class="text-end" id="totalCost">$0.00</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <div id="noSelectionMessage">
                        <p class="text-muted text-center mb-0">
                            Select a vehicle and enter charging details to see the booking summary.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- contentFor('scripts') %>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Set minimum date/time for booking
    const now = new Date();
    const minDateTime = now.toISOString().slice(0, 16);
    document.getElementById('startTime').min = minDateTime;

    // Update booking summary
    function updateBookingSummary() {
        const vehicleSelect = document.getElementById('vehicleId');
        const currentBattery = document.getElementById('currentBattery').value;
        const targetBattery = document.getElementById('targetBattery').value;
        const duration = document.getElementById('duration').value;
        const startTime = document.getElementById('startTime').value;

        if (vehicleSelect.value && currentBattery && targetBattery && duration && startTime) {
            const selectedVehicle = vehicleSelect.options[vehicleSelect.selectedIndex].text;
            const endTime = new Date(new Date(startTime).getTime() + duration * 60 * 60 * 1000);

            // Update summary content
            document.getElementById('selectedVehicleInfo').textContent = selectedVehicle;
            document.getElementById('sessionInfo').innerHTML = `
                Start: ${new Date(startTime).toLocaleString()}<br>
                Duration: ${duration} hours<br>
                Battery: ${currentBattery}% → ${targetBattery}%
            `;

            // Calculate estimated cost
            const chargingCost = duration * 10; // Example rate: $10/hour
            const serviceFee = 2.50;
            const total = chargingCost + serviceFee;

            document.getElementById('chargingCost').textContent = `$${chargingCost.toFixed(2)}`;
            document.getElementById('serviceFee').textContent = `$${serviceFee.toFixed(2)}`;
            document.getElementById('totalCost').textContent = `$${total.toFixed(2)}`;

            // Show summary
            document.getElementById('summaryContent').style.display = 'block';
            document.getElementById('noSelectionMessage').style.display = 'none';
        }
    }

    // Add event listeners
    ['vehicleId', 'currentBattery', 'targetBattery', 'duration', 'startTime'].forEach(id => {
        document.getElementById(id).addEventListener('change', updateBookingSummary);
    });

    // Remove AJAX form submission: let the form submit normally
});

document.getElementById('bookingForm').addEventListener('submit', function(e) {
    const currentBattery = parseInt(document.getElementById('currentBattery').value);
    const targetBattery = parseInt(document.getElementById('targetBattery').value);
    if (currentBattery >= targetBattery) {
        alert('Target battery level must be higher than current level');
        e.preventDefault();
    }
});
</script> 