<%- contentFor('body') %>
<div class="container mt-4">
    <!-- Welcome Banner -->
    <div class="row mb-4">
        <div class="col-12 position-relative">
            <div class="card bg-light shadow-sm">
                <div class="card-body d-flex flex-column flex-md-row align-items-md-center justify-content-between">
                    <div>
                        <h2 class="welcome-text mb-2">Welcome, <%= user.name %>!</h2>
                        <p class="text-muted mb-0">Your personal hub for managing electric vehicle charging, bookings, and more.</p>
                    </div>
                    <div class="d-none d-md-block ms-4">
                        <img src="/images/leaf.svg" alt="Leaf" style="width:64px;opacity:0.12;pointer-events:none;" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Row: Quick Navigation -->
    <div class="row mb-4 g-3">
        <div class="col-lg-12">
            <div class="row g-3">
                <div class="col-md-3">
                    <a href="/stations" class="text-decoration-none">
                        <div class="card hover-card shadow-sm h-100">
                            <div class="card-body text-center">
                                <i class="bi bi-lightning-charge-fill fs-1 text-success"></i>
                                <h5 class="mt-2">Find Stations</h5>
                                <p class="text-muted mb-0">Locate charging stations</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-md-3">
                    <a href="/bookings" class="text-decoration-none">
                        <div class="card hover-card shadow-sm h-100">
                            <div class="card-body text-center">
                                <i class="bi bi-calendar-check fs-1 text-success"></i>
                                <h5 class="mt-2">My Bookings</h5>
                                <p class="text-muted mb-0">View your bookings</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-md-3">
                    <a href="/vehicles/new" class="text-decoration-none">
                        <div class="card hover-card shadow-sm h-100">
                            <div class="card-body text-center">
                                <i class="bi bi-plus-circle fs-1 text-success"></i>
                                <h5 class="mt-2">Add Vehicle</h5>
                                <p class="text-muted mb-0">Register a vehicle</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-md-3">
                    <a href="/payments/page" class="text-decoration-none">
                        <div class="card hover-card shadow-sm h-100">
                            <div class="card-body text-center">
                                <i class="bi bi-credit-card fs-1 text-success"></i>
                                <h5 class="mt-2">Payments</h5>
                                <p class="text-muted mb-0">Manage payments</p>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Row: Profile, Stats, Vehicles, Payments -->
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="row mb-4">
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Profile Information</h5>
                            <div class="d-flex align-items-center mb-3">
                                <div class="avatar-circle me-3">
                                    <%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
                                </div>
                                <div>
                                    <h6 class="mb-0"><%= user.name || 'User' %></h6>
                                    <small class="text-muted"><%= user.email || 'No email provided' %></small>
                                </div>
                            </div>
                            <div class="user-details">
                                <% if (user.phoneNumber) { %>
                                    <p><i class="bi bi-telephone me-2"></i><%= user.phoneNumber %></p>
                                <% } %>
                                <% if (user.location && user.location.address) { %>
                                    <p><i class="bi bi-geo-alt me-2"></i><%= user.location.address %>, <%= user.location.city %>, <%= user.location.state %></p>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-8">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="card bg-primary text-white">
                                <div class="card-body">
                                    <h6 class="card-title">Total Vehicles</h6>
                                    <h3 class="mb-0"><%= vehicles ? vehicles.length : 0 %></h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-success text-white">
                                <div class="card-body">
                                    <h6 class="card-title">Account Status</h6>
                                    <h3 class="mb-0">Active</h3>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Vehicles Section -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">My Vehicles</h5>
                            <a href="/vehicles/new" class="btn btn-primary btn-sm">Add Vehicle</a>
                        </div>
                        <div class="card-body">
                            <% if (vehicles && vehicles.length > 0) { %>
                                <div class="table-responsive">
                                    <table class="table">
                                        <thead>
                                            <tr>
                                                <th>Make & Model</th>
                                                <th>License Plate</th>
                                                <th>Status</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% vehicles.forEach(vehicle => { %>
                                            <tr>
                                                <td><%= vehicle.make %> <%= vehicle.model %> (<%= vehicle.year %>)</td>
                                                <td><%= vehicle.licensePlate %></td>
                                                <td>
                                                    <span class="badge bg-success">Available</span>
                                                </td>
                                                <td>
                                                    <a href="/vehicles/<%= vehicle._id %>" class="btn btn-sm btn-info">Details</a>
                                                </td>
                                            </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } else { %>
                                <div class="text-center py-4">
                                    <p class="text-muted mb-3">You haven't added any vehicles yet.</p>
                                    <a href="/vehicles/new" class="btn btn-primary">Add Your First Vehicle</a>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Right Column -->
        <div class="col-lg-4">
            <!-- Payment Summary -->
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Payment Summary</h5>
                    <a href="/payments" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h6 class="mb-0">Total Spent</h6>
                            <small class="text-muted">All time</small>
                        </div>
                        <h4 class="mb-0 text-success">$<%= typeof totalSpent === 'number' ? totalSpent.toFixed(2) : '0.00' %></h4>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-0">Pending Payments</h6>
                            <small class="text-muted">To be paid</small>
                        </div>
                        <h4 class="mb-0 text-warning">$<%= typeof pendingAmount === 'number' ? pendingAmount.toFixed(2) : '0.00' %></h4>
                    </div>
                </div>
            </div>
            <!-- Recent Payments -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Recent Payments</h5>
                </div>
                <div class="card-body p-0">
                    <% if (recentPayments && recentPayments.length > 0) { %>
                        <div class="list-group list-group-flush">
                            <% recentPayments.forEach(payment => { %>
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">
                                                <i class="bi bi-lightning-charge text-primary me-2"></i>
                                                <%= payment.booking ? payment.booking.station.name : 'Charging Session' %>
                                            </h6>
                                            <small class="text-muted">
                                                <%= new Date(payment.createdAt).toLocaleDateString() %>
                                            </small>
                                        </div>
                                        <span class="badge bg-<%= payment.status === 'Completed' ? 'success' : 'warning' %>">
                                            $<%= payment.amount.toFixed(2) %>
                                        </span>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="text-center py-4">
                            <p class="text-muted mb-0">No recent payments</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<%- contentFor('scripts') %>
<script>
const ecoTips = [
    'Charge during off-peak hours to reduce grid strain and save money.',
    'Maintain your EV tire pressure for better efficiency and range.',
    'Precondition your EV while plugged in to save battery on the road.',
    'Drive smoothly and avoid rapid acceleration to maximize your range.',
    'Plan your trips to combine errands and reduce unnecessary driving.',
    'Use regenerative braking to recover energy while slowing down.',
    'Keep your EV clean and aerodynamic for optimal performance.',
    'Recycle your old EV batteries responsibly.',
    'Support renewable energy charging stations when possible.',
    'Share rides or carpool to further reduce your carbon footprint.'
];
function showRandomTip() {
    const tip = ecoTips[Math.floor(Math.random() * ecoTips.length)];
    document.getElementById('ecoTip').textContent = tip;
}
document.addEventListener('DOMContentLoaded', showRandomTip);

const evFacts = [
    'There are now over 10 million electric vehicles on the road worldwide!',
    'EVs convert over 77% of the electrical energy from the grid to power at the wheels.',
    'Electric vehicles produce zero tailpipe emissions, helping to reduce air pollution.',
    'Charging your EV with renewable energy makes your drive even greener.',
    'The first electric car was built in the 1800s, long before gasoline cars.',
    'EVs require less maintenance than gasoline vehicles because they have fewer moving parts.',
    'Many public charging stations are now powered by solar or wind energy.',
    'Fast chargers can add up to 200 miles of range in just 30 minutes.',
    'Some EVs can accelerate from 0 to 60 mph in under 3 seconds!',
    'Battery technology is improving rapidly, making EVs more affordable and practical.'
];
function showRandomFact() {
    const fact = evFacts[Math.floor(Math.random() * evFacts.length)];
    document.getElementById('evFact').textContent = fact;
}
document.addEventListener('DOMContentLoaded', showRandomFact);
</script> 