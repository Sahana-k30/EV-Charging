<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <img src="https://via.placeholder.com/120" alt="Profile" class="rounded-circle mb-3" style="width: 120px; height: 120px;">
                    <h2 class="mb-1"><%= user.name %></h2>
                    <p class="text-muted mb-3"><%= user.email %></p>
                    <hr>
                    <p><strong>Member since:</strong> <%= user.createdAt ? user.createdAt.toLocaleDateString() : '' %></p>
                    <a href="/dashboard" class="btn btn-primary mt-3">Back to Dashboard</a>
                </div>
            </div>
        </div>
    </div>
</div> 