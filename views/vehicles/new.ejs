<%- contentFor('body') %>
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card">
                <div class="card-header">
                    <h2 class="mb-0">Add New Vehicle</h2>
                </div>
                <div class="card-body">
                    <form action="/vehicles/new" method="POST" class="needs-validation" novalidate>
                        <div class="mb-3">
                            <label for="make" class="form-label">Make</label>
                            <input type="text" class="form-control" id="make" name="make" required>
                            <div class="invalid-feedback">
                                Please enter the vehicle make.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="model" class="form-label">Model</label>
                            <input type="text" class="form-control" id="model" name="model" required>
                            <div class="invalid-feedback">
                                Please enter the vehicle model.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="year" class="form-label">Year</label>
                            <input type="number" class="form-control" id="year" name="year" 
                                   min="2000" max="<%= new Date().getFullYear() + 1 %>" required>
                            <div class="invalid-feedback">
                                Please enter a valid year (2000 or later).
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="licensePlate" class="form-label">License Plate</label>
                            <input type="text" class="form-control" id="licensePlate" name="licensePlate" required>
                            <div class="invalid-feedback">
                                Please enter the license plate number.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="batteryCapacity" class="form-label">Battery Capacity (kWh)</label>
                            <input type="number" class="form-control" id="batteryCapacity" 
                                   name="batteryCapacity" min="1" required>
                            <div class="invalid-feedback">
                                Please enter the battery capacity.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="chargingType" class="form-label">Charging Type</label>
                            <select class="form-select" id="chargingType" name="chargingType" required>
                                <option value="">Select charging type</option>
                                <option value="Level 1">Level 1 (120V)</option>
                                <option value="Level 2">Level 2 (240V)</option>
                                <option value="DC Fast Charging">DC Fast Charging</option>
                            </select>
                            <div class="invalid-feedback">
                                Please select a charging type.
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Add Vehicle</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- contentFor('scripts') %>
<script>
// Form validation
(function () {
    'use strict'
    var forms = document.querySelectorAll('.needs-validation')
    Array.prototype.slice.call(forms)
        .forEach(function (form) {
            form.addEventListener('submit', function (event) {
                if (!form.checkValidity()) {
                    event.preventDefault()
                    event.stopPropagation()
                }
                form.classList.add('was-validated')
            }, false)
        })
})()
</script> 