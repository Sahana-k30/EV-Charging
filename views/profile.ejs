<%
const styles = `
<style>
.profile-card {
    max-width: 600px;
    margin: 2rem auto;
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
}
.profile-header {
    background-color: #f8f9fa;
    padding: 2rem;
    text-align: center;
}
.profile-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    margin-bottom: 1rem;
}
</style>
`;

const content = `
<div class="container">
    <div class="card profile-card">
        <div class="profile-header">
            <img src="https://via.placeholder.com/120" alt="Profile" class="profile-avatar">
            <h2><%= user.name %></h2>
            <p class="text-muted"><%= user.email %></p>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <h5>Account Details</h5>
                    <p><strong>Member since:</strong> <%= user.createdAt.toLocaleDateString() %></p>
                    <p><strong>Role:</strong> <%= user.role || 'User' %></p>
                </div>
                <div class="col-md-6 mb-3">
                    <h5>Statistics</h5>
                    <p><strong>Total Vehicles:</strong> <%= user.vehicles ? user.vehicles.length : 0 %></p>
                    <p><strong>Total Bookings:</strong> <%= user.bookings ? user.bookings.length : 0 %></p>
                </div>
            </div>
            <div class="text-center mt-3">
                <a href="/dashboard" class="btn btn-primary">Back to Dashboard</a>
            </div>
        </div>
    </div>
</div>
`;
%>

<%- include('layout', { styles, content }) %> 